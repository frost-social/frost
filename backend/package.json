{
  "name": "frost-backend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0+sha512.0e82714d1b5b43c74610193cb20734897c1d00de89d0e18420aebc5977fa13d780a9cb05734624e81ebd81cc876cd464794850641c48b9544326b5622ca29971",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc --project tsconfig.build.json",
    "rebuild": "pnpm clean && pnpm build",
    "check": "tsc --project tsconfig.check.json",
    "db:generate": "prisma generate --sql",
    "db:migrate": "prisma migrate dev --skip-generate --skip-seed",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --skip-generate --skip-seed",
    "update-spec": "mkdir -p openapi/generated && cp -r ../spec/generated/* openapi/generated",
    "start": "node --enable-source-maps dist/main",
    "start:dev": "node --enable-source-maps --watch dist/main",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "admin:lookup-user": "tsx scripts/lookup-user.ts",
    "admin:lookup-token": "tsx scripts/lookup-token.ts",
    "admin:delete-user": "tsx scripts/delete-user.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^5.1.0",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/passport": "^1.0.17",
    "@types/passport-http-bearer": "^1.0.41",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3"
  }
}
