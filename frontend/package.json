    "@tanstack/router-devtools": "^1.115.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.3.3"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.115.2",
    "@tanstack/router-plugin": "^1.115.2",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vite-tsconfig-paths": "^4.3.2"
  }
}
